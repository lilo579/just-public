---
export const prerender = false

import { PUBLIC_SITE_PAYLOAD_URL } from "../config/publicSite"
import type { ResolvedHomepage } from "../contracts/homepage"
import HomepageRenderer from "../components/HomepageRenderer.astro"

/**
 * Preview route (technical, SSR)
 * Requires explicit slug
 */

const slug = Astro.url.searchParams.get("slug")?.trim()
const MODE = "preview"

if (!slug) {
  throw new Error(
    "Missing slug. Use /preview?slug=YOUR_SLUG"
  )
}

const url = `${PUBLIC_SITE_PAYLOAD_URL}?slug=${encodeURIComponent(slug)}&mode=${MODE}`

const res = await fetch(url)

if (!res.ok) {
  const text = await res.text()
  throw new Error(
    `Failed to fetch homepage payload
Slug: ${slug}
Status: ${res.status}
Body: ${text}`
  )
}

const homepage = (await res.json()) as ResolvedHomepage
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Preview</title>
  </head>
  <body>
    <main style="max-width: 960px; margin: 0 auto; padding: 40px 20px;">
      <HomepageRenderer homepage={homepage} />
    </main>
  </body>
</html>
