---
export const prerender = false;

import { supabase } from '../../lib/supabase'

const { slug } = Astro.params

const url = new URL(Astro.request.url)
const hostOverride = url.searchParams.get('host')?.trim() ?? ''
const baseOverride = url.searchParams.get('base')?.trim() ?? ''

const hostHeader = Astro.request.headers.get('host') ?? ''
const hostFromHeader = hostHeader.split(':')[0].toLowerCase()

const host =
  hostOverride ||
  (hostFromHeader === 'localhost' ? 'www.3djewish.com.br' : hostFromHeader)

const { data: rows, error } = await supabase.rpc('public_get_product_by_host_and_slug', {
  p_host: host,
  p_slug: slug,
})

if (error) console.error('RPC error:', error)

const product = rows?.[0] ?? null

if (!product) {
  return new Response(`Produto não encontrado (host=${host}, slug=${slug})`, {
    status: 404,
    headers: { 'content-type': 'text/plain; charset=utf-8' },
  })
}

// Base URL (permite override em dev/test)
const baseUrl = baseOverride || `https://${host}`
const pageUrl = `${baseUrl}/p/${product.slug}`

const title = `${product.name} — ${product.company_name ?? 'Loja'}`
const description = product.description ?? `Veja detalhes de ${product.name}.`
const imageUrl = product.image_url ?? product.image_original_url ?? ''

const whatsappNumberRaw = product.whatsapp_number ?? ''
const whatsappNumber = whatsappNumberRaw.replace(/\D/g, '')

const waText = `Olá! Tenho interesse no produto: ${product.name}. Link: ${pageUrl}`
const waLink = whatsappNumber
  ? `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(waText)}`
  : null
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={pageUrl} />

    <!-- Open Graph (WhatsApp) -->
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:type" content="product" />
    <meta property="og:site_name" content={product.company_name ?? 'Just Websites'} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    {imageUrl && (
      <>
        <meta property="og:image" content={imageUrl} />
        <meta property="og:image:secure_url" content={imageUrl} />
        <meta property="og:image:type" content="image/webp" />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
      </>
    )}

    <!-- Twitter -->
    <meta name="twitter:card" content={imageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}

    {hostFromHeader === 'localhost' && <meta name="robots" content="noindex,nofollow" />}
  </head>

  <body>
    <a href="/">← Voltar</a>

    <h1>{product.name}</h1>

    <p><strong>Preço:</strong> R$ {product.price}</p>

    {product.description && <p>{product.description}</p>}

    {imageUrl && (
      <img
        src={imageUrl}
        alt={product.name}
        style="max-width: 520px; width: 100%; height: auto; border-radius: 12px;"
      />
    )}

    <div style="margin-top: 16px;">
      {waLink ? (
        <a
          href={waLink}
          style="display:inline-block;padding:12px 16px;border-radius:10px;background:#111;color:#fff;text-decoration:none;"
        >
          Comprar pelo WhatsApp
        </a>
      ) : (
        <p>WhatsApp não configurado.</p>
      )}
    </div>

    <hr style="margin: 24px 0;" />
    <p><small>Link para compartilhar: {pageUrl}</small></p>
  </body>
</html>
