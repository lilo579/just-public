---
export const prerender = false

import { PUBLIC_SITE_PAYLOAD_URL } from "../config/publicSite"
import type { ResolvedHomepage } from "../contracts/homepage"
import HomepageRenderer from "../components/HomepageRenderer.astro"

/**
 * Host preview route (technical, SSR)
 * Reads Host header and forwards it to Edge as bridge_v1
 */

const host = Astro.request.headers.get("host")?.trim()
const MODE = "public"

if (!host) {
  throw new Error("Missing Host header")
}

const url = `${PUBLIC_SITE_PAYLOAD_URL}?host=${encodeURIComponent(host)}&mode=${MODE}`

const res = await fetch(url)

if (!res.ok) {
  const text = await res.text()
  throw new Error(
    `Failed to fetch homepage payload
Host: ${host}
Status: ${res.status}
Body: ${text}`
  )
}

const homepage = (await res.json()) as ResolvedHomepage
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Host Preview</title>
  </head>
  <body>
    <main style="max-width: 960px; margin: 0 auto; padding: 40px 20px;">
      <HomepageRenderer homepage={homepage} />
    </main>
  </body>
</html>
