---
import HeroBlock from "./blocks/HeroBlock.astro";
import TrustBlock from "./blocks/TrustBlock.astro";
import ServicesBlock from "./blocks/ServicesBlock.astro";
import AboutBlock from "./blocks/AboutBlock.astro";
import CtaBlock from "./blocks/CtaBlock.astro";
import RichTextBlock from "./blocks/RichTextBlock.astro";
import FeaturesBlock from "./blocks/FeaturesBlock.astro";
import ProcessBlock from "./blocks/ProcessBlock.astro";
import InfoCardBlock from "./blocks/InfoCardBlock.astro";
import TestimonialsBlock from "./blocks/TestimonialsBlock.astro";
---

{
  Astro.props.homepage?.blocks?.map((block) => {
    switch (block.type) {
      case "hero":
        return <HeroBlock block={block} />;

      case "trust":
        return <TrustBlock block={block} />;

      case "services":
        return <ServicesBlock block={block} />;

      case "about":
        return <AboutBlock block={block} />;

      case "cta":
        return <CtaBlock block={block} />;

      case "rich_text":
        return <RichTextBlock block={block} />;

      case "features":
        return <FeaturesBlock block={block} />;

      case "process":
        return <ProcessBlock block={block} />;

      case "info_card":
        return <InfoCardBlock block={block} />;

      case "testimonials":
        return <TestimonialsBlock block={block} />;

      default:
        return null;
    }
  })
}
