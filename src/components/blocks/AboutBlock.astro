---
import type { AboutBlock as AboutBlockType } from "../../contracts/homepage";

const { block } = Astro.props as { block: AboutBlockType };
const { title, body, photoUrl } = block.content;

const paragraphs = body
  ? body.split("\n\n").map((p) => p.trim()).filter(Boolean)
  : [];
---

{(title || paragraphs.length > 0 || photoUrl) && (
  <section class="about">
    <div class="about__overlay" aria-hidden="true"></div>

    <div class="about__container">
      <div class="about__grid">
        {photoUrl && (
          <div class="about__media">
            <div class="about__media-inner">
              <div class="about__frame">
                <img
                  src={photoUrl}
                  alt={`${title || "Foto"}${block.content.title ? "" : ""}`}
                  class="about__image"
                />
              </div>
            </div>
          </div>
        )}

        <div class:list={[
          "about__content",
          photoUrl ? "about__content--with-photo" : "about__content--full"
        ]}>
          {title && <h2>{title}</h2>}

          {paragraphs.length > 0 && (
            <div class="about__body">
              {paragraphs.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
)}

<style>
  .about {
    position: relative;
    padding: 4rem 0;
  }

  .about__overlay {
    position: absolute;
    inset: 0;
    background: #ffffff;
  }

  .about__container {
  position: relative;
  z-index: 1;
  max-width: 1280px;
  margin: 0 auto;
  padding-left: 1.5rem;
  padding-right: 1.5rem;
}

  .about__grid {
    display: grid;
    gap: 1.5rem;
    align-items: center;
  }

  .about__media {
    order: 2;
  }

  .about__content--with-photo {
    order: 1;
  }

  .about__media-inner {
    position: relative;
    margin-top: 0.5rem;
  }

  .about__frame {
    aspect-ratio: 4 / 5;
    border-radius: 0.75rem;
    overflow: hidden;
    background: #ffffff;
    box-shadow:
      0 1px 3px 0 hsl(220 15% 15% / 0.04),
      0 4px 16px -4px hsl(220 15% 15% / 0.06);
    border: 1px solid hsl(30 8% 88% / 0.3);
  }

  .about__image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center 25%;
  }

  .about h2 {
    margin: 0;
    font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, Arial, sans-serif;
    font-size: 1.875rem;
    line-height: 2.25rem;
    font-weight: 700;
    color: hsl(220 15% 15%);
    text-align: left;
  }

  .about__body {
    margin-top: 1.25rem;
    display: grid;
    gap: 1rem;
    font-size: 1.125rem;
    color: hsl(220 15% 15% / 0.7);
    line-height: 1.625;
    text-align: left;
  }

  .about__body p {
    margin: 0;
  }

  @media (min-width: 640px) {
    .about__overlay {
      background: hsl(220 15% 15% / 0.015);
    }
  }

  @media (min-width: 1024px) {
  .about {
    padding: 6rem 0;
  }

  .about__grid {
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 3rem;
  }

  .about__media {
    order: 1;
    max-width: 32rem;
  }

  .about__content--with-photo {
    order: 2;
    max-width: none;
  }

  .about__media-inner {
    margin-top: 0;
  }

  .about__frame {
    border-radius: 1rem;
  }

  .about h2 {
    font-size: 2.25rem;
    line-height: 2.5rem;
  }

  .about__body {
    margin-top: 1.5rem;
    gap: 1.25rem;
    line-height: 1.85;
  }
}
</style>
