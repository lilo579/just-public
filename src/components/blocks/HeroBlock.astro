---
import type { HeroBlock as HeroBlockType } from "../../contracts/homepage"

const { block } = Astro.props as { block: HeroBlockType }
const { title, subtitle } = block.content
---

<section class="hero">
  {title && <h1>{title}</h1>}
  {subtitle && <p>{subtitle}</p>}
</section>

<style>
  .hero {
    padding: 32px 0 20px;
  }

  .hero h1 {
    margin: 0 0 16px;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .hero p {
    margin: 0;
    max-width: 760px;
    font-size: 1.1rem;
    color: #4b5563;
  }
</style>
